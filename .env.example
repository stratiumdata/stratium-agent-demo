# Copy this file to .env and fill in real values. docker-compose reads .env automatically.

# ── AI Agent API keys ─────────────────────────────────────────────────────────
# Optional for the *delegation* demo flow (which only exercises agent-gateway
# RPCs via grpcurl). Required if you docker-exec into a container and actually
# run the `claude` or `codex` CLI against the upstream API.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Model selection (optional) ────────────────────────────────────────────────
# Override the model each CLI uses when running the MCP-driven demos
# (`make demo-flow-mcp-claude` / `make demo-flow-mcp-codex`).
# Leave blank to let each CLI pick its default.
#
# Useful when:
#   - your default tier is rate-/quota-limited and you want to switch to a
#     cheaper model for the demo
#   - you want to test a specific model's tool-use behavior
#
# Examples:
#   ANTHROPIC_MODEL=claude-sonnet-4-6      # latest Sonnet
#   ANTHROPIC_MODEL=claude-haiku-4-5       # cheaper, faster, still tool-capable
#   OPENAI_MODEL=gpt-5-mini                # cheaper than gpt-5.5
#   OPENAI_MODEL=gpt-4o                    # widely available, lower per-token cost
ANTHROPIC_MODEL=
OPENAI_MODEL=

# ── Demo user credentials (Keycloak, stratium realm) ─────────────────────────
# Seeded in keycloak/realm-export.json. Override only if you've modified the realm.
DEMO_USER=user
DEMO_PASS=password123

# ── Agent-gateway image pin (override to test a different build) ─────────────
AGENT_GATEWAY_IMAGE=stratiumdata/agent-gateway:eval-1.0.8
